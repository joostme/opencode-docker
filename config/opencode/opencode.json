{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0"
  },
  "permission": {
    "*": "ask",
    "todoread": "allow",
    "todowrite": "allow",
    "task": "allow",
    "context7_*": "allow",
    "playwright_*": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "/home/opencode/.ssh/*": "deny",
      "/home/opencode/.local/share/opencode/auth.json": "deny",
      "*.pem": "deny",
      "*.key": "deny",
      "*credentials*": "deny",
      "*secret*": "deny"
    },
    "edit": "allow",
    "write": "allow",
    "webfetch": "allow",
    "glob": "allow",
    "grep": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "git branch*": "allow",
      "git rev-parse*": "allow",
      "git remote -v*": "allow",
      "git ls-files*": "allow",
      "git blame*": "allow",
      "gh --help*": "allow",
      "gh help*": "allow",
      "gh completion*": "allow",
      "gh org list*": "allow",
      "gh issue list*": "allow",
      "gh issue status*": "allow",
      "gh issue view*": "allow",
      "gh pr list*": "allow",
      "gh pr status*": "allow",
      "gh pr view*": "allow",
      "gh search *": "allow",
      "gh pr checks*": "allow",
      "gh pr diff*": "allow",
      "gh repo list*": "allow",
      "gh repo view*": "allow",
      "gh run watch*": "allow",
      "gh release list*": "allow",
      "gh release view*": "allow",
      "gh workflow list*": "allow",
      "gh workflow view*": "allow",
      "gh run list*": "allow",
      "gh run view*": "allow",
      "gh cache list*": "allow",
      "gh project field-list*": "allow",
      "gh project item-list*": "allow",
      "gh project list*": "allow",
      "gh project view*": "allow",
      "gh ruleset check*": "allow",
      "gh ruleset list*": "allow",
      "gh ruleset view*": "allow",
      "gh repo gitignore*": "allow",
      "gh repo license*": "allow",
      "gh repo autolink list*": "allow",
      "gh repo autolink view*": "allow",
      "gh gist list*": "allow",
      "gh gist view*": "allow",
      "gh label list*": "allow",
      "gh status*": "allow",
      "gh alias list*": "allow",
      "gh config get*": "allow",
      "gh config list*": "allow",
      "gh codespace logs*": "allow",
      "gh codespace ports*": "allow",
      "gh codespace list*": "allow",
      "gh codespace view*": "allow",
      "gh extension list*": "allow",
      "gh extension search*": "allow",
      "gh attestation trusted-root*": "allow",
      "docker *": "deny",
      "sudo *": "deny",
      "su *": "deny",
      "chmod 777 *": "deny",
      "curl * | bash": "deny",
      "curl * | sh": "deny",
      "wget * | bash": "deny",
      "wget * | sh": "deny"
    },
    "external_directory": {
      "*": "ask",
      "/repos/**": "allow"
    }
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
      "enabled": true
    },
    "playwright": {
      "type": "remote",
      "url": "http://playwright-mcp:8931/mcp",
      "enabled": true
    }
  },
  "autoupdate": false
}
